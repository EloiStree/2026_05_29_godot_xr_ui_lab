[node name="UiLabTextSubmitAtReady" parent="Arena/CanvasLayer/Control/PrefabShort128x64/Code" parent_id_path=PackedInt32Array(525735575, 1831408484) index="0" unique_id=184630064]
text = "extends Node

@onready var array: Array[bool] = []
var car:Node

func _ready():
	array.resize(128 * 64)
	array.fill(false)
	print(\"Hello 128x64\")

func _on_received_target(target: Node):
	print(\"Target:\", target)
	car=target
	car.set_wheels(1,1)
	while (true):
		await get_tree().create_timer(0.1).timeout
		randomize_array()
		car.print_text(array,\"Hello world\")
		draw()
		if car.has_method(\"set_wheels\"):
			# car.set_wheels(randf_range(-1,1),randf_range(-1,1))
			pass
		

func draw():
		car.set_screen_128x64_to(array)
func fill():
	array.fill(true)
	draw()

func empty():
	array.fill(false)
	draw()

func randomize_array():
	for i in range(array.size()):
		array[i] = randi() % 2 == 0
	draw()"

